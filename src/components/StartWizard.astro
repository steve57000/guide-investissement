---
---
<section class="start-wizard" data-start-wizard>
  <div class="wizard-shell">
    <div class="wizard-header">
      <div>
        <p class="eyebrow">Assistant pédagogique</p>
        <h2>Construire un parcours adapté au point de départ de Steve</h2>
        <p class="muted">Réponds aux questions pour obtenir une synthèse éducative : priorité, allocation issue des exemples du guide, plateforme à comparer et actions concrètes.</p>
      </div>
      <div class="wizard-progress-card" aria-live="polite">
        <span data-step-label>Étape 1/6</span>
        <strong data-progress-percent>17 %</strong>
        <div class="wizard-progress"><i data-progress-bar></i></div>
      </div>
    </div>

    <div class="wizard-card" data-question-card></div>
    <div class="wizard-result is-hidden" data-result-card></div>
  </div>

  <script>
    import { buildWizardRecommendation } from '../utils/wizard';

    const root = document.querySelector('[data-start-wizard]');
    if (root) {
      const questions = [
        { id: 'security', title: 'As-tu une épargne de sécurité ?', badge: 'Sécurité', options: ['Oui', 'En cours', 'Non'] },
        { id: 'amount', title: 'Combien peux-tu investir par mois ?', badge: 'Budget', options: ['50 €', '75 €', '100 €', '150 €', '200 €', '300 €', '500 €', '1000 €'] },
        { id: 'horizon', title: 'Horizon d’investissement', badge: 'Horizon', options: ['moins de 5 ans', '5 à 10 ans', '10 à 20 ans', '20 ans et plus'] },
        { id: 'risk', title: 'Tolérance au risque', badge: 'Risque', options: ['prudente', 'équilibrée', 'dynamique'] },
        { id: 'platform', title: 'Plateformes actuelles', badge: 'Plateforme', options: ['N26', 'Revolut', 'Les deux', 'Aucune', 'Autre'] },
        { id: 'crypto', title: 'Souhaites-tu investir en crypto ?', badge: 'Crypto', options: ['Non', 'Oui, petite poche BTC/ETH', 'Oui, mais je débute'] },
      ];

      const answers = {};
      let current = 0;
      const questionCard = root.querySelector('[data-question-card]');
      const resultCard = root.querySelector('[data-result-card]');
      const stepLabel = root.querySelector('[data-step-label]');
      const progressPercent = root.querySelector('[data-progress-percent]');
      const progressBar = root.querySelector('[data-progress-bar]');
      const euro = (value) => `${Number(value).toLocaleString('fr-FR')} €`;
      const pct = (value) => `${Number(value).toLocaleString('fr-FR')} %`;
      const cleanAmount = (value) => Number(String(value).replace(/[^0-9]/g, ''));
      const assetRows = (recommendation) => [
        { label: 'ETF Monde / PEA', amount: recommendation.etfMonde, percentage: recommendation.etfPercentage },
        ...(recommendation.bitcoin > 0 ? [{ label: 'Bitcoin', amount: recommendation.bitcoin, percentage: recommendation.bitcoinPercentage }] : []),
        ...(recommendation.ethereum > 0 ? [{ label: 'Ethereum', amount: recommendation.ethereum, percentage: recommendation.ethereumPercentage }] : []),
      ];

      const setProgress = () => {
        const percent = Math.round(((current + 1) / questions.length) * 100);
        stepLabel.textContent = `Étape ${Math.min(current + 1, questions.length)}/${questions.length}`;
        progressPercent.textContent = `${percent} %`;
        progressBar.style.width = `${percent}%`;
      };

      const renderQuestion = () => {
        setProgress();
        const question = questions[current];
        questionCard.classList.remove('is-hidden');
        resultCard.classList.add('is-hidden');
        questionCard.innerHTML = `
          <span class="badge">${question.badge}</span>
          <h3>${question.title}</h3>
          <div class="wizard-options">
            ${question.options.map((option) => `<button type="button" class="wizard-option${answers[question.id] === option ? ' is-selected' : ''}" data-answer="${option}">${option}</button>`).join('')}
          </div>
          <div class="wizard-controls">
            <button type="button" class="btn secondary" data-back ${current === 0 ? 'disabled' : ''}>Retour</button>
            <span class="muted">Contenu éducatif uniquement, pas un conseil financier personnalisé.</span>
          </div>
        `;
      };

      const buildResult = () => {
        const recommendation = buildWizardRecommendation({
          amount: cleanAmount(answers.amount),
          crypto: answers.crypto,
          horizon: answers.horizon,
          security: answers.security,
          risk: answers.risk,
          platform: answers.platform,
        });
        const rows = assetRows(recommendation);
        const hasCryptoAllocation = recommendation.bitcoin > 0 || recommendation.ethereum > 0;

        questionCard.classList.add('is-hidden');
        resultCard.classList.remove('is-hidden');
        stepLabel.textContent = 'Résultat';
        progressPercent.textContent = '100 %';
        progressBar.style.width = '100%';
        resultCard.innerHTML = `
          <div class="result-top">
            <div><p class="eyebrow">Synthèse prudente</p><h3>Parcours de démarrage proposé</h3></div>
            <div class="wizard-badges"><span class="badge">Sécurité</span><span class="badge badge-pea">PEA</span><span class="badge badge-cto">ETF</span>${hasCryptoAllocation ? '<span class="badge badge-crypto">Crypto limitée</span>' : ''}<span class="badge badge-ifu">À vérifier</span></div>
          </div>
          <div class="result-grid">
            <article><span>Profil résumé</span><strong>${answers.security} épargne • ${answers.amount}/mois • ${answers.horizon} • risque ${answers.risk}</strong></article>
            <article><span>Priorité immédiate</span><strong>${recommendation.priority}</strong></article>
            <article><span>Plateforme à comparer</span><strong>${recommendation.platformRecommendation}</strong></article>
          </div>
          <div class="allocation-result">
            <h4>Allocation proposée selon tes réponses</h4>
            <div class="allocation-split allocation-split-${rows.length}">${rows.map((row) => `<div><b>${euro(row.amount)}</b><span>${row.label} · ${pct(row.percentage)}</span></div>`).join('')}</div>
            <p class="muted">${recommendation.explanation}</p>
            ${recommendation.objective ? `<p class="muted">Objectif : ${recommendation.objective}${recommendation.recommendedHorizon ? ` Horizon indicatif : ${recommendation.recommendedHorizon}.` : ''}</p>` : ''}
          </div>
          <div class="result-columns"><div><h4>Pourquoi ce résultat ?</h4><ul><li>${recommendation.explanation}</li><li>${recommendation.priority}</li></ul></div><div><h4>Points à vérifier</h4><ul>${recommendation.warnings.map((item) => `<li>${item}</li>`).join('')}</ul></div></div>
          <div class="result-columns result-actions"><div><h4>Prochaines actions</h4><ol>${recommendation.nextActions.map((item) => `<li>${item}</li>`).join('')}</ol></div><div><h4>Rappel important</h4><p class="muted">Le résultat est pédagogique et doit rester cohérent avec tes réponses, ta fiscalité, tes frais et ton horizon.</p></div></div>
          <div class="wizard-controls"><button type="button" class="btn secondary" data-back-result>Modifier mes réponses</button><button type="button" class="btn" data-restart>Recommencer</button></div>
        `;
      };

      root.addEventListener('click', (event) => {
        const answerButton = event.target.closest('[data-answer]');
        if (answerButton) {
          answers[questions[current].id] = answerButton.dataset.answer;
          if (current < questions.length - 1) { current += 1; renderQuestion(); } else { buildResult(); }
        }
        if (event.target.closest('[data-back]') && current > 0) { current -= 1; renderQuestion(); }
        if (event.target.closest('[data-back-result]')) { current = questions.length - 1; renderQuestion(); }
        if (event.target.closest('[data-restart]')) { Object.keys(answers).forEach((key) => delete answers[key]); current = 0; renderQuestion(); }
      });

      renderQuestion();
    }
  </script>
</section>
