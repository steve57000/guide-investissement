<section class="portfolio-journal content-wide" aria-labelledby="portfolio-journal-title">
  <div class="journal-panel">
    <p class="eyebrow">Outil local</p>
    <h2 id="portfolio-journal-title">Journal interactif</h2>
    <p class="muted">Les données saisies restent uniquement dans ce navigateur via localStorage. Aucun backend n’est créé et aucune donnée personnelle n’est collectée.</p>

    <form class="journal-form" data-journal-form>
      <label>Date<input name="date" type="date" required /></label>
      <label>Type d’action<input name="type" type="text" placeholder="Versement, achat, vente…" required /></label>
      <label>Montant<input name="amount" type="text" inputmode="decimal" placeholder="50 €" /></label>
      <label>Support<input name="asset" type="text" placeholder="ETF Monde, Bitcoin…" /></label>
      <label>Plateforme<input name="platform" type="text" placeholder="PEA, courtier, exchange…" /></label>
      <label class="journal-form__wide">Commentaire<textarea name="comment" rows="3" placeholder="Raison, document conservé, point à vérifier…"></textarea></label>
      <button class="btn" type="submit">Ajouter la ligne</button>
    </form>
  </div>

  <div class="journal-panel">
    <div class="journal-toolbar">
      <div>
        <p class="eyebrow">Historique local</p>
        <h3>Lignes enregistrées</h3>
      </div>
      <div class="tool-actions" aria-label="Actions du journal">
        <button class="btn secondary" type="button" data-journal-sort>Trier par date</button>
        <button class="btn secondary" type="button" data-journal-export-csv>Exporter CSV</button>
        <button class="btn secondary" type="button" data-journal-export-json>Exporter JSON</button>
        <label class="btn secondary file-action">Importer JSON<input type="file" accept="application/json,.json" data-journal-import /></label>
        <button class="btn secondary danger" type="button" data-journal-clear>Vider le journal</button>
      </div>
    </div>
    <div class="journal-feedback" data-journal-feedback aria-live="polite" hidden></div>
    <div class="journal-summary" data-journal-summary aria-live="polite"></div>
    <p class="journal-empty" data-journal-empty>Aucune ligne enregistrée pour le moment.</p>
    <div class="table-wrap journal-table-wrap">
      <table class="journal-table">
        <thead><tr><th>Date</th><th>Action</th><th>Montant</th><th>Support</th><th>Plateforme</th><th>Commentaire</th><th></th></tr></thead>
        <tbody data-journal-body></tbody>
      </table>
    </div>
  </div>
</section>

<script is:inline>
  const storageKey = 'guide-investissement-portfolio-journal';
  const fields = ['date', 'type', 'amount', 'asset', 'platform', 'comment'];
  const form = document.querySelector('[data-journal-form]');
  const body = document.querySelector('[data-journal-body]');
  const empty = document.querySelector('[data-journal-empty]');
  const clearButton = document.querySelector('[data-journal-clear]');
  const sortButton = document.querySelector('[data-journal-sort]');
  const exportCsvButton = document.querySelector('[data-journal-export-csv]');
  const exportJsonButton = document.querySelector('[data-journal-export-json]');
  const importInput = document.querySelector('[data-journal-import]');
  const summary = document.querySelector('[data-journal-summary]');
  const feedback = document.querySelector('[data-journal-feedback]');

  const limits = { date: 10, type: 80, amount: 40, asset: 80, platform: 80, comment: 500 };
  const normalizeText = (value, field) => String(value ?? '').trim().slice(0, limits[field] ?? 120);
  const isValidDate = (value) => !value || /^\d{4}-\d{2}-\d{2}$/.test(value);
  const normalizeRow = (row) => fields.reduce((entry, field) => ({ ...entry, [field]: normalizeText(row?.[field], field) }), {});
  const validateRows = (value) => {
    if (!Array.isArray(value)) return null;
    const rows = value.map(normalizeRow).filter((row) => isValidDate(row.date) && (row.date || row.type || row.amount || row.asset || row.platform || row.comment));
    return rows.length <= 1000 ? rows : rows.slice(0, 1000);
  };
  const loadRows = () => {
    try {
      const rows = JSON.parse(localStorage.getItem(storageKey) || '[]');
      return validateRows(rows) ?? [];
    } catch { return []; }
  };
  const saveRows = (rows) => localStorage.setItem(storageKey, JSON.stringify(rows.map(normalizeRow)));
  const showFeedback = (message, type = 'ok') => {
    feedback.textContent = message;
    feedback.className = `journal-feedback ${type}`;
    feedback.hidden = false;
  };
  const parseAmount = (value) => {
    const cleaned = String(value || '').replace(/\s/g, '').replace(/€/g, '').replace(',', '.').replace(/[^0-9.-]/g, '');
    const number = Number(cleaned);
    return Number.isFinite(number) ? number : null;
  };
  const download = (content, filename, type) => {
    const blob = new Blob([content], { type });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    link.click();
    URL.revokeObjectURL(url);
  };
  const csvEscape = (value) => `"${String(value ?? '').replace(/"/g, '""')}"`;
  const cell = (value) => {
    const td = document.createElement('td');
    td.textContent = value || '—';
    return td;
  };
  const renderSummary = (rows) => {
    const total = rows.reduce((sum, row) => sum + (parseAmount(row.amount) ?? 0), 0);
    const numericCount = rows.filter((row) => parseAmount(row.amount) !== null).length;
    const last = rows.at(-1);
    const platforms = [...new Set(rows.map((row) => row.platform.trim()).filter(Boolean))];
    summary.innerHTML = '';
    [
      ['Lignes', rows.length || '0'],
      ['Total montants numériques', numericCount ? `${total.toLocaleString('fr-FR', { maximumFractionDigits: 2 })} €` : 'Aucun montant numérique'],
      ['Dernière action', last ? `${last.date || 'Sans date'} — ${last.type || 'Action non précisée'}` : 'Aucune'],
      ['Plateformes utilisées', platforms.length ? platforms.join(', ') : 'Aucune plateforme renseignée'],
    ].forEach(([label, value]) => {
      const item = document.createElement('article');
      item.innerHTML = `<span>${label}</span><strong></strong>`;
      item.querySelector('strong').textContent = value;
      summary.append(item);
    });
  };
  const renderRows = () => {
    const rows = loadRows();
    body.innerHTML = '';
    empty.hidden = rows.length > 0;
    renderSummary(rows);
    rows.forEach((row, index) => {
      const tr = document.createElement('tr');
      fields.forEach((key) => tr.append(cell(row[key])));
      const actions = document.createElement('td');
      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'journal-delete';
      remove.textContent = 'Supprimer';
      remove.addEventListener('click', () => {
        saveRows(loadRows().filter((_, rowIndex) => rowIndex !== index));
        renderRows();
      });
      actions.append(remove);
      tr.append(actions);
      body.append(tr);
    });
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const rows = loadRows();
    const nextRow = normalizeRow(Object.fromEntries(fields.map((field) => [field, data.get(field)])));
    if (!nextRow.date || !nextRow.type || !isValidDate(nextRow.date)) {
      showFeedback('Date et type d’action sont obligatoires, avec une date au format valide.', 'error');
      return;
    }
    rows.push(nextRow);
    saveRows(rows);
    form.reset();
    showFeedback('Ligne ajoutée au journal.', 'ok');
    renderRows();
  });

  sortButton?.addEventListener('click', () => {
    const rows = loadRows().sort((a, b) => String(a.date || '').localeCompare(String(b.date || '')));
    saveRows(rows);
    showFeedback('Journal trié par date croissante.', 'ok');
    renderRows();
  });

  exportCsvButton?.addEventListener('click', () => {
    const rows = loadRows();
    const header = ['Date', 'Action', 'Montant', 'Support', 'Plateforme', 'Commentaire'];
    const lines = [header, ...rows.map((row) => fields.map((field) => row[field]))].map((line) => line.map(csvEscape).join(';'));
    download(`\uFEFF${lines.join('\r\n')}`, 'journal-investissement.csv', 'text/csv;charset=utf-8');
    showFeedback('Export CSV généré.', 'ok');
  });

  exportJsonButton?.addEventListener('click', () => {
    download(JSON.stringify(loadRows(), null, 2), 'journal-investissement.json', 'application/json;charset=utf-8');
    showFeedback('Export JSON généré.', 'ok');
  });

  importInput?.addEventListener('change', async () => {
    const file = importInput.files?.[0];
    if (!file) return;
    try {
      const parsed = JSON.parse(await file.text());
      const importedRows = validateRows(parsed);
      if (!importedRows) throw new Error('Format invalide');
      const mode = confirm('OK : ajouter les lignes importées aux lignes existantes. Annuler : remplacer toutes les lignes existantes après confirmation.') ? 'append' : 'replace';
      let nextRows = importedRows;
      if (mode === 'append') nextRows = [...loadRows(), ...importedRows];
      if (mode === 'replace' && !confirm('Remplacer définitivement le journal local par le fichier importé ?')) return;
      saveRows(nextRows);
      showFeedback(`${importedRows.length} ligne(s) importée(s).`, 'ok');
      renderRows();
    } catch {
      showFeedback('Import impossible : le fichier JSON ne contient pas un journal valide.', 'error');
    } finally {
      importInput.value = '';
    }
  });

  clearButton?.addEventListener('click', () => {
    if (confirm('Vider toutes les lignes du journal enregistrées dans ce navigateur ?')) {
      saveRows([]);
      showFeedback('Journal vidé.', 'ok');
      renderRows();
    }
  });

  renderRows();
</script>
