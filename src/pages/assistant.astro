---
import BaseLayout from '../layouts/BaseLayout.astro';
import StartWizard from '../components/StartWizard.astro';
---
<BaseLayout title="Assistant de démarrage | Guide Investissement 2026–2055" description="Questionnaire pédagogique pour choisir un parcours : épargne de sécurité, PEA, ETF Monde, crypto limitée, plateforme principale.">
  <section class="content-page assistant-hero">
    <p class="eyebrow">Guide Investissement 2026–2055</p>
    <h1>Assistant de démarrage</h1>
    <p class="lead">Un questionnaire pédagogique pour aider Steve à choisir un parcours cohérent : épargne de sécurité, PEA, ETF Monde, crypto limitée et plateforme principale à comparer.</p>
    <div class="callout a-retenir"><strong>Important</strong><p>Le résultat sert à structurer la réflexion. Il ne constitue pas un conseil financier personnalisé, ni une recommandation réglementée d’achat ou de vente.</p></div>
  <div class="actions"><a class="btn secondary" href={`${import.meta.env.BASE_URL}scenarios-crise`.replace(/\/\//g, '/')}>Préparer les scénarios de crise</a></div>
  </section>
  <StartWizard />
</BaseLayout>
