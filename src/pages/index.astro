---
import BaseLayout from '../layouts/BaseLayout.astro';
import Simulator from '../components/Simulator.astro';
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path = '') => `${baseUrl}${path.replace(/^\/+/, '')}`;
const plans = [
  { amount: '50 €/mois', allocation: '35 € ETF Monde • 10 € Bitcoin • 5 € Ethereum', badge: 'Débutant', goal: 'Installer l’habitude sans complexité.' },
  { amount: '100 €/mois', allocation: '75 € ETF Monde • 15 € Bitcoin • 10 € Ethereum', badge: 'PEA + Crypto', goal: 'Construire un socle diversifié.' },
  { amount: '200 €/mois', allocation: '155 € ETF Monde • 30 € Bitcoin • 15 € Ethereum', badge: 'Long terme', goal: 'Accélérer avec une stratégie suivie.' },
];
---
<BaseLayout>
<section class="hero"><div class="eyebrow">2026–2055 • Patrimoine progressif</div><h1>Construire un patrimoine, dès 50 € par mois.</h1><p>Un guide concret pour prioriser le PEA, comparer les plateformes, cadrer une petite poche crypto et tester des hypothèses de rendement sans confondre simulation et promesse.</p><div class="actions"><a class="btn" href={withBase('commencer-50')}>Commencer avec 50 €</a><a class="btn secondary" href={withBase('plateformes')}>Comparer les plateformes</a><a class="btn secondary" href={withBase('simulations')}>Tester une simulation</a></div></section>
<section class="section plan-section"><div class="section-head"><div><p class="eyebrow">Plan recommandé</p><h2>Une progression simple : ETF d’abord, crypto limitée, suivi régulier.</h2></div><p class="muted">Ces exemples sont pédagogiques : ils doivent être adaptés à votre épargne de sécurité, votre fiscalité et votre tolérance au risque.</p></div><div class="grid">{plans.map((plan) => <article class="card plan-card"><span class="badge">{plan.badge}</span><h3>{plan.amount}</h3><p class="allocation">{plan.allocation}</p><p class="muted">{plan.goal}</p><div class="mini-chart"><i style={`height:${plan.amount.startsWith('50')?'42%':'100%'}`} /><i style={`height:${plan.amount.startsWith('200')?'68':'48'}%`} /><i style="height:30%" /></div></article>)}</div><div class="actions"><a class="btn" href={withBase('plateformes')}>Voir les plateformes</a><a class="btn secondary" href={withBase('simulations')}>Voir les simulations</a></div></section>
<section class="section grid"><article class="card"><span class="badge">PEA</span><h3>Priorité aux enveloppes françaises</h3><p class="muted">Le PEA est à étudier en premier pour les ETF éligibles avant de multiplier les comptes.</p></article><article class="card"><span class="badge">CTO</span><h3>Comparer avant d’ouvrir</h3><p class="muted">Frais, IFU, investissement programmé et simplicité fiscale comptent autant que l’interface.</p></article><article class="card"><span class="badge">Crypto</span><h3>Poche volontairement limitée</h3><p class="muted">Bitcoin et Ethereum peuvent être inclus, mais uniquement avec une volatilité acceptée.</p></article></section>
<section class="section"><Simulator /></section>
</BaseLayout>
