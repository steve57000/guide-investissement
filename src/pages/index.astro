---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlanCards from '../components/PlanCards.astro';
import Simulator from '../components/Simulator.astro';
import { allocations } from '../data/allocations';
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path = '') => `${baseUrl}${path.replace(/^\/+/, '')}`;
const starterAllocation = allocations.find(({ total }) => total === 50) ?? allocations[0];
const euro = (value: number) => `${value.toLocaleString('fr-FR')} €`;
const pct = (value: number) => `${value.toLocaleString('fr-FR')} %`;
const dashboardRows = [
  { label: 'ETF Monde', amount: starterAllocation.etfMonde, percentage: starterAllocation.etfPercentage },
  { label: 'Bitcoin', amount: starterAllocation.bitcoin, percentage: starterAllocation.bitcoinPercentage },
  { label: 'Ethereum', amount: starterAllocation.ethereum, percentage: starterAllocation.ethereumPercentage },
];
---
<BaseLayout>
<section class="hero hero-premium">
  <div class="hero-copy">
    <div class="eyebrow">2026–2055 • Patrimoine progressif</div>
    <h1>Construire un patrimoine, dès 50 € par mois.</h1>
    <p>Un guide concret pour prioriser le PEA, comparer les plateformes, cadrer une petite poche crypto et tester des hypothèses de rendement sans confondre simulation et promesse.</p>
    <div class="actions"><a class="btn" href={withBase('commencer-50')}>Commencer avec 50 €</a><a class="btn secondary" href={withBase('plateformes')}>Comparer les plateformes</a><a class="btn secondary" href={withBase('simulations')}>Tester une simulation</a></div>
  </div>
  <aside class="hero-dashboard" aria-label="Exemple de plan à 50 euros par mois">
    <div class="dashboard-topline"><span class="badge">Plan {euro(starterAllocation.total)}/mois</span><strong>Allocation simple</strong></div>
    <div class="dashboard-total"><span>Versement mensuel</span><b>{euro(starterAllocation.total)}</b></div>
    {dashboardRows.map(({ label, amount, percentage }) => (
      <div class="allocation-row">
        <span>{label}</span>
        <strong>{euro(amount)} · {pct(percentage)}</strong>
        <i style={`--w:${percentage}%`}></i>
      </div>
    ))}
    <p class="muted">Un point de départ pédagogique : enveloppe lisible, frais surveillés, crypto volontairement limitée.</p>
  </aside>
</section>
<section class="section plan-section section-wide"><div class="section-head"><div><p class="eyebrow">Plan recommandé</p><h2>Une progression simple : ETF d’abord, crypto limitée, suivi régulier.</h2></div><p class="muted">Ces exemples sont pédagogiques : ils doivent être adaptés à votre épargne de sécurité, votre fiscalité et votre tolérance au risque.</p></div><PlanCards /><div class="actions"><a class="btn" href={withBase('plateformes')}>Voir les plateformes</a><a class="btn secondary" href={withBase('simulations')}>Voir les simulations</a></div></section>
<section class="section grid home-principles"><article class="card"><span class="badge">PEA</span><h3>Priorité aux enveloppes françaises</h3><p class="muted">Le PEA est à étudier en premier pour les ETF éligibles avant de multiplier les comptes.</p></article><article class="card"><span class="badge">CTO</span><h3>Comparer avant d’ouvrir</h3><p class="muted">Frais, IFU, investissement programmé et simplicité fiscale comptent autant que l’interface.</p></article><article class="card"><span class="badge">Crypto</span><h3>Poche volontairement limitée</h3><p class="muted">Bitcoin et Ethereum peuvent être inclus, mais uniquement avec une volatilité acceptée.</p></article></section>

<section class="section compound-section">
  <div class="section-head">
    <div><p class="eyebrow">Pourquoi commencer maintenant ?</p><h2>Le temps long transforme une petite régularité en vraie trajectoire patrimoniale.</h2></div>
    <p class="muted">Même 50 €/mois peuvent installer une discipline, laisser les intérêts composés travailler et rendre les hausses d’effort futures plus naturelles.</p>
  </div>
  <div class="grid">
    <article class="card"><span class="badge">Régularité</span><h3>Automatiser l’habitude</h3><p class="muted">Un versement mensuel modeste évite d’attendre le “bon moment” et réduit la dépendance aux émotions de marché.</p></article>
    <article class="card"><span class="badge">Temps long</span><h3>2026–2055 donne de l’espace</h3><p class="muted">Plus l’horizon est long, plus les cycles de marché peuvent être traversés avec méthode et patience.</p></article>
    <article class="card"><span class="badge">Intérêts composés</span><h3>Les gains peuvent produire des gains</h3><p class="muted">Les simulations montrent pourquoi commencer tôt peut compter davantage que chercher une allocation parfaite dès le premier mois.</p></article>
  </div>
  <div class="actions"><a class="btn" href={withBase('simulations')}>Tester les simulations</a><a class="btn secondary" href={withBase('portefeuille-steve')}>Voir le Portefeuille Steve</a></div>
</section>
<section class="section"><Simulator /></section>
</BaseLayout>
