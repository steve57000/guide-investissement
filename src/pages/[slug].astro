---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AllocationTable from '../components/AllocationTable.astro';
export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((page) => page.id !== 'simulations' && page.id !== 'crypto')
    .map((page) => ({ params: { slug: page.id.replace(/\.mdx?$/, '') }, props: { page } }));
}
const { page } = Astro.props;
const { Content } = await render(page);
---
<BaseLayout title={`${page.data.title} | Guide Investissement 2026–2055`} description={page.data.description}>
  <article class="content-page prose">
    <p class="eyebrow">Guide Investissement 2026–2055</p>
    <h1>{page.data.title}</h1>
    <p class="muted">{page.data.description}</p>
    <Content />
    {page.id === 'commencer-50' && <><h2>Allocations officielles centralisées</h2><AllocationTable /></>}
    {page.id === 'plan-action' && <><h2>Allocation de départ officielle</h2><AllocationTable /></>}
  </article>
</BaseLayout>
