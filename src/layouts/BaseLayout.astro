---
import '../styles/global.css';
import { footerLinks, mainNav, understandSections } from '../data/navigation';
const { title = 'Guide Investissement 2026–2055', description = 'Guide éducatif pour investir progressivement.' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://steve57000.github.io';
const withBase = (path = '') => `${baseUrl}${path.replace(/^\/+/, '')}`;
const withSite = (path = '') => new URL(withBase(path), `${siteUrl}/`).toString();
const canonicalUrl = new URL(Astro.url.pathname, `${siteUrl}/`).toString();
const ogImageUrl = withSite('og-image.png');
const socialSquareUrl = withSite('social-square.png');
const understandNav = understandSections.flatMap((section) => section.links);
const normalizePath = (path = '/') => {
  const basePath = new URL(baseUrl, 'https://example.com').pathname;
  let current = path.startsWith(basePath) ? path.slice(basePath.length) : path.replace(/^\/+/, '');
  current = current.replace(/^\/+|\/+$/g, '');
  return current;
};
const activePath = normalizePath(Astro.url.pathname);
const isActive = (href = '') => normalizePath(href) === activePath;
const hasActiveUnderstandLink = understandNav.some(([href]) => isActive(href));
---
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#061426" />
    <link rel="icon" href={withBase('favicon.ico')} sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase('favicon-16x16.png')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('favicon-32x32.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('site.webmanifest')} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Guide Investissement 2026–2055" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:alt" content="Guide Investissement 2026–2055" />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image" content={socialSquareUrl} />
    <meta property="og:image:width" content="1254" />
    <meta property="og:image:height" content="1254" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav" data-main-nav>
      <div class="container nav-container nav-inner">
        <a class="brand" href={baseUrl}>Guide <span>Investissement</span></a>
        <button class="nav-toggle" type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="main-navigation" data-nav-toggle>
          <span class="nav-toggle-line"></span>
          <span class="nav-toggle-line"></span>
          <span class="nav-toggle-line"></span>
        </button>
        <div class="links" id="main-navigation" data-nav-menu>
          {mainNav.map(([href,label]) => {
            const active = isActive(href);
            return <a class:list={[{ 'nav-active': active }]} aria-current={active ? 'page' : undefined} href={withBase(href)}>{label}</a>;
          })}
          <div class:list={["nav-group", { "nav-group-active": hasActiveUnderstandLink }]}>
            <button class="nav-group-button" type="button" aria-expanded="false" aria-controls="understand-navigation">Comprendre</button>
            <div class="nav-dropdown" id="understand-navigation">
              {understandSections.map((section) => (
                <section class="nav-dropdown-section" aria-label={section.title}>
                  <p class="nav-dropdown-title">{section.title}</p>
                  {section.links.map(([href,label]) => {
                    const active = isActive(href);
                    return <a class:list={[{ 'nav-active': active }]} aria-current={active ? 'page' : undefined} href={withBase(href)}>{label}</a>;
                  })}
                </section>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>
    <main class="container"><slot /></main>
    <footer class="footer">
      <div class="container footer-inner">
        <p>Contenu éducatif uniquement : ne constitue pas un conseil financier personnalisé. Sources à compléter avec documents officiels avant toute décision.</p>
        <nav class="footer-links" aria-label="Liens utiles">
          {footerLinks.map(([href, label]) => <a href={withBase(href)}>{label}</a>)}
        </nav>
      </div>
    </footer>
    <script is:inline>
      const navRoot = document.querySelector('[data-main-nav]');
      const navToggle = document.querySelector('[data-nav-toggle]');
      const navMenu = document.querySelector('[data-nav-menu]');

      if (navRoot && navToggle && navMenu) {
        const setMenuOpen = (isOpen) => {
          navRoot.classList.toggle('is-open', isOpen);
          navToggle.setAttribute('aria-expanded', String(isOpen));
          navToggle.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
        };

        navToggle.addEventListener('click', () => {
          setMenuOpen(navToggle.getAttribute('aria-expanded') !== 'true');
        });

        navMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => setMenuOpen(false));
        });

        navMenu.querySelectorAll('.nav-group-button').forEach((button) => {
          button.addEventListener('click', () => {
            if (window.matchMedia('(max-width: 1279px)').matches) {
              const group = button.closest('.nav-group');
              const isOpen = group.classList.toggle('is-dropdown-open');
              button.setAttribute('aria-expanded', String(isOpen));
            }
          });
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setMenuOpen(false);
        });

        document.addEventListener('click', (event) => {
          if (!navRoot.contains(event.target)) setMenuOpen(false);
        });
      }
    </script>
  </body>
</html>
